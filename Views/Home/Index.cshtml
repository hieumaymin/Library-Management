@model DashboardStats
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stat Cards Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-book"></i></div>
            <div>
                <div class="stat-value">@Model.TotalBooks</div>
                <div class="stat-label">Tổng số sách</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-users"></i></div>
            <div>
                <div class="stat-value">@Model.TotalReaders</div>
                <div class="stat-label">Độc giả</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-handshake"></i></div>
            <div>
                <div class="stat-value">@Model.ActiveLoans</div>
                <div class="stat-label">Đang mượn</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-clock"></i></div>
            <div>
                <div class="stat-value">@Model.OverdueLoans</div>
                <div class="stat-label">Quá hạn trả</div>
            </div>
        </div>
    </div>
</div>

<!-- Second row -->
<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-layer-group"></i></div>
            <div>
                <div class="stat-value">@Model.TotalBookTitles</div>
                <div class="stat-label">Đầu sách</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-tools"></i></div>
            <div>
                <div class="stat-value">@Model.DamagedBooks</div>
                <div class="stat-label">Sách hư hỏng</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-skull-crossbones"></i></div>
            <div>
                <div class="stat-value">@Model.LostBooks</div>
                <div class="stat-label">Sách mất</div>
            </div>
        </div>
    </div>
</div>

<!-- Tables row -->
<div class="row g-3">
    <!-- Active loans -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header-custom">
                <h5><i class="fas fa-handshake me-2 text-primary"></i>Đang mượn (sắp tới hạn)</h5>
                <a asp-controller="Loan" asp-action="Index" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                @if (!Model.RecentLoans.Any())
                {
                    <div class="text-center py-4 text-secondary" style="font-size:0.875rem">
                        <i class="fas fa-check-circle text-success mb-2 d-block" style="font-size:1.5rem"></i>
                        Không có phiếu mượn nào đang mở
                    </div>
                }
                else
                {
                    <table class="table table-custom mb-0">
                        <thead>
                            <tr>
                                <th>Sách</th>
                                <th>Độc giả</th>
                                <th>Hạn trả</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in Model.RecentLoans)
                            {
                                <tr>
                                    <td>@loan.Book?.Title</td>
                                    <td>@loan.Reader?.Name</td>
                                    <td>
                                        @if (loan.IsOverdue)
                                        {
                                            <span class="badge-status badge-danger">@loan.DueDate.ToString("dd/MM/yyyy")</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status badge-info">@loan.DueDate.ToString("dd/MM/yyyy")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <!-- Overdue loans -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header-custom">
                <h5><i class="fas fa-clock me-2 text-danger"></i>Sách quá hạn trả</h5>
                <a asp-controller="Loan" asp-action="Search" asp-route-status="overdue" class="btn btn-sm btn-outline-danger">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                @if (!Model.OverdueList.Any())
                {
                    <div class="text-center py-4 text-secondary" style="font-size:0.875rem">
                        <i class="fas fa-check-circle text-success mb-2 d-block" style="font-size:1.5rem"></i>
                        Không có sách quá hạn
                    </div>
                }
                else
                {
                    <table class="table table-custom mb-0">
                        <thead>
                            <tr>
                                <th>Sách</th>
                                <th>Độc giả</th>
                                <th>Trễ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in Model.OverdueList)
                            {
                                <tr>
                                    <td>@loan.Book?.Title</td>
                                    <td>@loan.Reader?.Name</td>
                                    <td><span class="badge-status badge-danger">@loan.DaysOverdue ngày</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
