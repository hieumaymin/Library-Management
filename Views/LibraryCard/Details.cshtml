@model MyLibraryDemo.Data.Models.Reader
@using MyLibraryDemo.Data.Models
@{
    ViewData["Title"] = "Thẻ thư viện";
    var card = Model.LibraryCard;
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-controller="Reader" asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold">Thẻ thư viện – @Model.Name</h4>
</div>

<div class="card" style="max-width:520px">
    <div class="card-body p-4">
        @if (card == null)
        {
            <div class="text-center py-4">
                <i class="fas fa-id-card text-secondary mb-3 d-block" style="font-size:3rem;opacity:.3"></i>
                <p class="text-secondary">Độc giả chưa có thẻ thư viện.</p>
                <a asp-action="Create" asp-route-readerId="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i>Cấp thẻ mới
                </a>
            </div>
        }
        else
        {
            <!-- Card display -->
            <div class="p-3 rounded-3 mb-4" style="background:linear-gradient(135deg,#1d4ed8,#0f172a);color:white">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div style="font-size:.7rem;opacity:.7;text-transform:uppercase;letter-spacing:.1em">Thư viện</div>
                        <div style="font-size:1.1rem;font-weight:700">@Model.Name</div>
                    </div>
                    <i class="fas fa-id-card" style="font-size:1.5rem;opacity:.5"></i>
                </div>
                <div style="font-size:1.4rem;font-weight:700;letter-spacing:.15em;margin:0.5rem 0">
                    @card.Barcode
                </div>
                <div class="d-flex justify-content-between" style="font-size:.75rem;opacity:.8">
                    <span>Cấp: @card.IssueDate.ToString("dd/MM/yyyy")</span>
                    <span>HH: @card.ExpiryDate.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <dl class="row mb-3">
                <dt class="col-sm-5 text-secondary small">Trạng thái</dt>
                <dd class="col-sm-7">
                    <span class="badge-status @(card.IsValid ? "badge-success" : card.IsExpired ? "badge-warning" : "badge-danger")">
                        <i class="fas @(card.IsValid ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                        @card.StatusDisplay
                    </span>
                </dd>

                <dt class="col-sm-5 text-secondary small">Hạn sử dụng</dt>
                <dd class="col-sm-7">@card.ExpiryDate.ToString("dd/MM/yyyy")</dd>
            </dl>

            <div class="d-flex gap-2">
                <a asp-action="RenewBySearch" asp-route-barcode="@card.Barcode" class="btn btn-primary">
                    <i class="fas fa-rotate-right me-2"></i>Gia hạn thẻ
                </a>
                @if (card.IsActive)
                {
                    <form asp-action="Deactivate" asp-route-id="@card.Id" method="post"
                          onsubmit="return confirm('Vô hiệu hóa thẻ này?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-ban me-2"></i>Vô hiệu hóa
                        </button>
                    </form>
                }
                else
                {
                    <form asp-action="Activate" asp-route-id="@card.Id" method="post"
                          onsubmit="return confirm('Kích hoạt lại thẻ này?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-success">
                            <i class="fas fa-check-circle me-2"></i>Kích hoạt thẻ
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</div>
