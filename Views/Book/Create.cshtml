@model MyLibraryDemo.Data.Models.Book
@using MyLibraryDemo.Data.Models
@{
    ViewData["Title"] = "Thêm sách mới";
}

<div class="d-flex align-items-center gap-2 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left"></i>
    </a>
    <h4 class="mb-0 fw-bold">Thêm sách mới</h4>
</div>

<div class="card" style="max-width:700px">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert-floating error mb-3"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tên sách..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Author" class="form-label"></label>
                    <input asp-for="Author" class="form-control" placeholder="Tên tác giả..." />
                    <span asp-validation-for="Author" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Publisher" class="form-label"></label>
                    <input asp-for="Publisher" class="form-control" placeholder="Nhà xuất bản..." />
                </div>

                <div class="col-md-4">
                    <label asp-for="Category" class="form-label"></label>
                    <input asp-for="Category" class="form-control" placeholder="Văn học, Khoa học..." />
                </div>

                <div class="col-md-4">
                    <label asp-for="Language" class="form-label"></label>
                    <input asp-for="Language" class="form-control" placeholder="Tiếng Việt, English..." />
                </div>

                <div class="col-md-4">
                    <label asp-for="PublicationYear" class="form-label"></label>
                    <input asp-for="PublicationYear" class="form-control" placeholder="2024" />
                    <span asp-validation-for="PublicationYear" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" type="number" min="0" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select"
                            asp-items="Html.GetEnumSelectList<BookStatus>()"></select>
                </div>

                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả nội dung sách..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save me-2"></i>Lưu sách
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}